<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Обнять?</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --tg-bg: #17212b;
    --tg-secondary: #232e3c;
    --tg-surface: #1c2733;
    --tg-blue: #2b8cf5;
    --tg-blue-dark: #1a7ae0;
    --tg-text: #f5f5f5;
    --tg-subtext: #708499;
    --tg-divider: #2b3a4a;
    --tg-green: #4dcd5e;
    --tg-red: #e05252;
  }

  html, body {
    height: 100%;
    background: var(--tg-bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--tg-text);
    overflow: hidden;
  }

  #app {
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  /* Background pattern like Telegram */
  #app::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 20% 20%, rgba(43,140,245,0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(43,140,245,0.06) 0%, transparent 50%);
    pointer-events: none;
  }

  .card {
    background: var(--tg-secondary);
    border-radius: 20px;
    padding: 28px 24px 32px;
    width: calc(100% - 32px);
    max-width: 380px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    position: relative;
    z-index: 2;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4), 0 2px 8px rgba(0,0,0,0.3);
    animation: cardIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(30px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .duck-wrap {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-bottom: 20px;
  }

  .duck-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.3s;
  }

  .title {
    font-size: 20px;
    font-weight: 700;
    color: var(--tg-text);
    text-align: center;
    margin-bottom: 6px;
    letter-spacing: -0.3px;
  }

  .subtitle {
    font-size: 14px;
    color: var(--tg-subtext);
    text-align: center;
    margin-bottom: 28px;
    line-height: 1.5;
  }

  .username {
    color: var(--tg-blue);
    font-weight: 600;
  }

  .buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
  }

  .btn {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: transform 0.12s, opacity 0.12s, box-shadow 0.12s;
    letter-spacing: 0.1px;
    position: relative;
    overflow: hidden;
  }

  .btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: white;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .btn:active::after { opacity: 0.1; }
  .btn:active { transform: scale(0.97); }

  .btn-hug {
    background: var(--tg-blue);
    color: #fff;
    box-shadow: 0 4px 16px rgba(43,140,245,0.4);
  }

  .btn-hug:hover { background: var(--tg-blue-dark); box-shadow: 0 4px 20px rgba(43,140,245,0.5); }

  .btn-no {
    background: var(--tg-surface);
    color: var(--tg-subtext);
    border: 1px solid var(--tg-divider);
  }

  .btn-no:hover { background: #243041; color: var(--tg-text); }

  /* ===== HUG STATE ===== */
  #hug-screen {
    display: none;
    height: 100vh;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 10;
    animation: fadeIn 0.5s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  #hug-screen.visible { display: flex; }

  .hug-card {
    background: var(--tg-secondary);
    border-radius: 24px;
    padding: 32px 24px;
    width: calc(100% - 32px);
    max-width: 380px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
    animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    z-index: 2;
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0.7); }
    to { opacity: 1; transform: scale(1); }
  }

  .hug-duck {
    width: 200px;
    height: 200px;
    object-fit: contain;
    margin-bottom: 20px;
    animation: bounce 1s infinite alternate ease-in-out;
  }

  @keyframes bounce {
    from { transform: translateY(0) rotate(-3deg); }
    to { transform: translateY(-8px) rotate(3deg); }
  }

  .hug-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--tg-text);
    text-align: center;
    margin-bottom: 8px;
  }

  .hug-sub {
    font-size: 14px;
    color: var(--tg-subtext);
    text-align: center;
    line-height: 1.5;
    margin-bottom: 20px;
  }

  .hug-user {
    color: var(--tg-blue);
    font-weight: 700;
    font-size: 16px;
  }

  .timer-bar-wrap {
    width: 100%;
    background: var(--tg-surface);
    border-radius: 8px;
    height: 4px;
    overflow: hidden;
    margin-top: 8px;
  }

  .timer-bar {
    height: 100%;
    background: var(--tg-blue);
    border-radius: 8px;
    width: 100%;
    animation: drain 5s linear forwards;
  }

  @keyframes drain {
    from { width: 100%; }
    to { width: 0%; }
  }

  .timer-text {
    font-size: 12px;
    color: var(--tg-subtext);
    margin-top: 8px;
    text-align: center;
  }

  /* ===== CONFETTI ===== */
  #confetti-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  /* Telegram-style top bar */
  .tg-bar {
    position: fixed;
    top: 0;
    left: 0; right: 0;
    height: 56px;
    background: var(--tg-secondary);
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 12px;
    border-bottom: 1px solid var(--tg-divider);
    z-index: 100;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  .tg-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2b8cf5, #1a7ae0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .tg-bar-info { flex: 1; }
  .tg-bar-name { font-size: 15px; font-weight: 600; color: var(--tg-text); }
  .tg-bar-status { font-size: 12px; color: var(--tg-green); }

  .tg-bar-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: none;
    border: none;
    color: var(--tg-blue);
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
</head>
<body>


<canvas id="confetti-canvas"></canvas>

<!-- Main screen -->
<div id="app" style="padding-top: 56px;">
  <div class="card">
    <div class="duck-wrap">
      <img id="main-duck" src="https://i.pinimg.com/originals/95/43/11/954311243767211851bc3c117f2cb492.gif" alt="duck">
    </div>
    <div class="title">oluhZXC хочет обнять тебя 🤗</div>
    <div class="subtitle"></div>
    <div class="buttons">
      <button class="btn btn-hug" onclick="doHug()">Обнять</button>
      <button class="btn btn-no" onclick="doNo()">Не обнимать</button>
    </div>
  </div>
</div>

<!-- Hug success screen -->
<div id="hug-screen">
  <div class="hug-card">
    <img class="hug-duck" src="https://i.pinimg.com/originals/12/85/67/12856764f67e51be15194a1294952e66.gif" alt="hugging ducks">
    <div class="hug-title">🎉 Поздравляю!</div>
    <div class="hug-sub">Вы обняли пользователя<br><span class="hug-user">oluhZXC</span></div>
    
    <div class="timer-text"></div>
  </div>
</div>

<script>
  function doHug() {
    document.getElementById('app').style.display = 'none';
    const hs = document.getElementById('hug-screen');
    hs.classList.add('visible');
    startConfetti();
    setTimeout(() => {
      try { window.close(); } catch(e) {}
      // fallback: blank the page
      document.body.innerHTML = '<div style="height:100vh;display:flex;align-items:center;justify-content:center;background:#17212b;color:#708499;font-family:Inter,sans-serif;font-size:15px;">💙 Объятие доставлено</div>';
    }, 5000);
  }

  function doNo() {
    window.location.href = 'https://www.youtube.com/watch?v=Mvaosumc4hU&list=RDMvaosumc4hU&start_radio=1';
  }

  // ===== CONFETTI =====
  function startConfetti() {
    const canvas = document.getElementById('confetti-canvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const colors = ['#2b8cf5','#4dcd5e','#f5c518','#e05252','#a855f7','#f97316','#ec4899','#06b6d4'];
    const pieces = [];

    for (let i = 0; i < 120; i++) {
      pieces.push({
        x: Math.random() * canvas.width,
        y: -20 - Math.random() * 200,
        w: 8 + Math.random() * 8,
        h: 4 + Math.random() * 4,
        color: colors[Math.floor(Math.random() * colors.length)],
        vx: (Math.random() - 0.5) * 3,
        vy: 2 + Math.random() * 4,
        rot: Math.random() * 360,
        rotSpeed: (Math.random() - 0.5) * 6,
        opacity: 0.85 + Math.random() * 0.15,
        side: Math.random() < 0.5 ? 'left' : 'right'
      });
    }

    // Bias confetti to sides
    pieces.forEach(p => {
      if (p.side === 'left') {
        p.x = Math.random() * (canvas.width * 0.25);
        p.vx = 0.5 + Math.random() * 2;
      } else {
        p.x = canvas.width * 0.75 + Math.random() * (canvas.width * 0.25);
        p.vx = -(0.5 + Math.random() * 2);
      }
    });

    let frame = 0;
    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      pieces.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;
        p.rot += p.rotSpeed;
        p.vy += 0.04;
        if (p.y > canvas.height + 20) {
          p.y = -20;
          p.x = p.side === 'left'
            ? Math.random() * canvas.width * 0.25
            : canvas.width * 0.75 + Math.random() * canvas.width * 0.25;
        }
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot * Math.PI / 180);
        ctx.globalAlpha = p.opacity;
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
        ctx.restore();
      });
      frame++;
      if (frame < 360) requestAnimationFrame(draw); // ~6 seconds
    }
    draw();
  }
</script>
</body>
</html>
